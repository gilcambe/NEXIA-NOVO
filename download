<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<title>Viajante Pro — Guia Operacional</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@100;200;300;400;600;700;800&family=DM+Serif+Display:ital@0;1&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root {
  --bg:  #F7F4EF; --bg2: #EFECE6; --bg3: #E5E1D8; --sur: #FFFFFF;
  --brd: rgba(0,0,0,0.07); --brd2: rgba(0,0,0,0.14);
  --ink: #0E0E0D; --ink3: #3D3C38; --ink4: #8A8780; --ink5: #C0BDB5;
  --gold: #B8935A; --g2: rgba(184,147,90,0.1);
  --grn: #1F7A4A;  --gr2: rgba(31,122,74,0.09);
  --red: #C0392B;  --rd2: rgba(192,57,43,0.08);
  --amb: #B5620A;  --am2: rgba(181,98,10,0.09);
  --blu: #1A4080;  --bl2: rgba(26,64,128,0.08);
  --pur: #5B2D8E;  --pr2: rgba(91,45,142,0.08);
  --ff: 'Sora',system-ui,sans-serif;
  --ffs:'DM Serif Display',Georgia,serif;
  --ffm:'JetBrains Mono',monospace;
  --nh: 72px; --ease: cubic-bezier(0.22,1,0.36,1);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{background:#18160f;min-height:100vh;display:flex;align-items:center;justify-content:center;-webkit-font-smoothing:antialiased;}
body{width:100%;display:flex;align-items:center;justify-content:center;min-height:100vh;font-family:var(--ff);}

/* SHELL */
#shell{position:relative;width:100%;max-width:400px;height:100vh;max-height:880px;background:var(--bg);overflow:hidden;display:flex;flex-direction:column;}
@media(min-width:460px){#shell{border-radius:46px;box-shadow:0 40px 120px rgba(0,0,0,0.65),0 0 0 1px rgba(255,255,255,0.06),inset 0 1px 0 rgba(255,255,255,0.1);height:880px;}}
@media(max-width:460px){html{background:var(--bg);}}

/* STATUS BAR */
.sbar{height:44px;flex-shrink:0;display:flex;align-items:flex-end;justify-content:space-between;padding:0 24px 9px;background:var(--ink);}
.sbar-time{font-family:var(--ffm);font-size:11px;font-weight:500;color:rgba(255,255,255,0.65);}
.sbar-ico{font-size:10px;color:rgba(255,255,255,0.45);letter-spacing:2px;}

/* TOPBAR */
#topbar{flex-shrink:0;background:var(--ink);padding:12px 18px 14px;border-bottom:1px solid rgba(255,255,255,0.06);}
.tb-r1{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;}
.tb-wordmark{font-family:'DM Serif Display',Georgia,serif;font-style:italic;font-weight:400;font-size:1rem;color:var(--ink);letter-spacing:0.02em;}
.tb-role{font-family:var(--ff);font-size:7px;font-weight:700;letter-spacing:0.22em;text-transform:uppercase;padding:3px 10px;background:var(--gold);color:#FFF;}
.tb-av{width:28px;height:28px;border-radius:50%;background:rgba(255,255,255,0.08);display:flex;align-items:center;justify-content:center;font-family:var(--ff);font-size:9px;font-weight:700;color:rgba(255,255,255,0.7);cursor:pointer;}

/* GROUP SELECT */
.grp-row{display:flex;gap:7px;}
.grp-btn{flex:1;padding:8px 4px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);font-family:var(--ff);font-size:9px;font-weight:600;color:rgba(255,255,255,0.35);cursor:pointer;text-align:center;transition:all 0.18s;line-height:1.3;}
.grp-btn.active{border-color:var(--gold);color:#FFF;background:rgba(184,147,90,0.12);}
.grp-btn:hover:not(.active){color:rgba(255,255,255,0.65);border-color:rgba(255,255,255,0.18);}

/* PROGRESS STRIP */
#prog-strip{flex-shrink:0;background:var(--ink);padding:10px 18px 12px;border-bottom:1px solid rgba(255,255,255,0.06);}
.ps-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;}
.ps-label{font-family:var(--ff);font-size:7.5px;font-weight:600;letter-spacing:0.22em;text-transform:uppercase;color:rgba(255,255,255,0.35);}
.ps-count{font-family:var(--ffm);font-size:1rem;color:var(--gold);}
.ps-bar{height:3px;background:rgba(255,255,255,0.08);overflow:hidden;}
.ps-fill{height:100%;background:var(--gold);transition:width 0.55s var(--ease);}

/* BOTTOM NAV */
#bnav{position:absolute;bottom:0;left:0;right:0;height:var(--nh);background:rgba(247,244,239,0.97);backdrop-filter:blur(24px);border-top:1px solid var(--brd);display:grid;grid-template-columns:repeat(4,1fr);z-index:60;}
.nb{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:4px;border:none;background:none;cursor:pointer;-webkit-tap-highlight-color:transparent;position:relative;padding:0;}
.nb-ico{font-size:19px;transition:transform 0.28s var(--ease);}
.nb-lbl{font-family:var(--ff);font-size:7px;font-weight:600;letter-spacing:0.16em;text-transform:uppercase;color:var(--ink5);transition:color 0.2s;}
.nb.active .nb-lbl{color:var(--ink);}
.nb.active .nb-ico{transform:scale(1.18) translateY(-2px);}
.nb.active::after{content:'';position:absolute;bottom:0;left:50%;transform:translateX(-50%);width:20px;height:2px;background:var(--gold);}
.nb.crise-btn .nb-lbl{color:var(--red);}
.nb.crise-btn.active .nb-lbl{color:var(--red);}
.nb.crise-btn.active::after{background:var(--red);}

/* VIEW ROOT */
#view-root{flex:1;overflow-y:auto;overflow-x:hidden;padding-bottom:var(--nh);-webkit-overflow-scrolling:touch;}
#view-root::-webkit-scrollbar{display:none;}
.view-enter{animation:ven 0.26s var(--ease);}
@keyframes ven{from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:none;}}

/* TOAST */
#toast-root{position:absolute;top:180px;left:50%;transform:translateX(-50%);z-index:999;width:calc(100% - 32px);display:flex;flex-direction:column;gap:6px;align-items:center;pointer-events:none;}
.toast{background:var(--ink);color:var(--bg);padding:10px 18px;font-family:var(--ff);font-size:10.5px;border-left:2.5px solid var(--gold);animation:tin 0.25s var(--ease);max-width:100%;}
.toast.red{border-left-color:var(--red);}
.toast.grn{border-left-color:var(--grn);}
@keyframes tin{from{opacity:0;transform:translateY(-6px);}to{opacity:1;}}

/* SHARED */
.eyebrow{font-family:var(--ff);font-size:7.5px;font-weight:600;letter-spacing:0.32em;text-transform:uppercase;color:var(--ink4);}
.sec{padding:18px 20px 0;}
.pill{display:inline-flex;align-items:center;font-family:var(--ff);font-size:7px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;padding:2px 8px;}
.pill-grn{background:var(--gr2);color:var(--grn);border:1px solid rgba(31,122,74,0.2);}
.pill-amb{background:var(--am2);color:var(--amb);border:1px solid rgba(181,98,10,0.2);}
.pill-red{background:var(--rd2);color:var(--red);border:1px solid rgba(192,57,43,0.2);}
.pill-blu{background:var(--bl2);color:var(--blu);border:1px solid rgba(26,64,128,0.2);}
.pill-gold{background:var(--g2);color:var(--gold);border:1px solid rgba(184,147,90,0.22);}
.pill-ink{background:rgba(12,12,11,0.07);color:var(--ink);border:1px solid rgba(12,12,11,0.12);}
.pill-pur{background:var(--pr2);color:var(--pur);border:1px solid rgba(91,45,142,0.2);}
.f-lbl{display:block;font-family:var(--ff);font-size:7.5px;font-weight:600;letter-spacing:0.24em;text-transform:uppercase;color:var(--ink4);margin-bottom:7px;}
.f-inp{width:100%;padding:11px 0;background:transparent;border:none;border-bottom:1px solid var(--brd);font-family:var(--ff);font-size:13px;font-weight:300;color:var(--ink);outline:none;transition:border-color 0.2s;-webkit-appearance: none; appearance: none;}
.f-inp:focus{border-bottom-color:var(--gold);}
.f-inp::placeholder{color:var(--ink5);}
.f-sel{width:100%;padding:11px 0;background:transparent;border:none;border-bottom:1px solid var(--brd);font-family:var(--ff);font-size:13px;font-weight:300;color:var(--ink);outline:none;-webkit-appearance: none; appearance: none;;cursor:pointer;transition:border-color 0.2s;}
.f-sel:focus{border-bottom-color:var(--gold);}
.f-ta{width:100%;padding:11px 0;background:transparent;border:none;border-bottom:1px solid var(--brd);font-family:var(--ff);font-size:13px;font-weight:300;color:var(--ink);outline:none;resize:none;min-height:72px;transition:border-color 0.2s;}
.f-ta:focus{border-bottom-color:var(--gold);}
.f-ta::placeholder{color:var(--ink5);}
.btn-blk{width:100%;padding:14px;background:var(--ink);color:var(--bg);font-family:var(--ff);font-size:8.5px;font-weight:700;letter-spacing:0.28em;text-transform:uppercase;border:none;cursor:pointer;transition:opacity 0.2s;}
.btn-blk:hover{opacity:0.82;}
.btn-blk.gold{background:var(--gold);}
.btn-blk.grn{background:var(--grn);}
.btn-blk.red{background:var(--red);}

/* ══ MANIFESTO ══ */
.manifest-item{background:var(--sur);border:1px solid var(--brd);margin-bottom:7px;overflow:hidden;transition:border-color 0.2s;}
.manifest-item.checked-in{border-left:3px solid var(--grn);}
.manifest-item.sos{border-left:3px solid var(--red);animation:sosblink 1.5s ease-in-out infinite;}
@keyframes sosblink{0%,100%{border-left-color:var(--red);}50%{border-left-color:rgba(192,57,43,0.3);}}
.mi-header{display:flex;align-items:center;gap:12px;padding:12px 14px;cursor:pointer;user-select:none;}
.mi-num{font-family:var(--ffm);font-size:10px;color:var(--ink5);width:20px;flex-shrink:0;}
.mi-av{width:34px;height:34px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:var(--ff);font-size:12px;font-weight:700;flex-shrink:0;}
.mi-info{flex:1;min-width:0;}
.mi-name{font-family:var(--ff);font-size:12.5px;font-weight:500;color:var(--ink);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.mi-tags{display:flex;gap:4px;flex-wrap:wrap;margin-top:3px;}
.mi-status{flex-shrink:0;font-size:16px;}
.mi-chevron{font-size:10px;color:var(--ink5);flex-shrink:0;transition:transform 0.25s var(--ease);}
.manifest-item.open .mi-chevron{transform:rotate(180deg);}
.mi-body{display:none;padding:0 14px 14px;border-top:1px solid var(--brd);}
.manifest-item.open .mi-body{display:block;}
.mi-body-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px 18px;margin-top:12px;}
.mi-field-lbl{font-family:var(--ff);font-size:7px;font-weight:600;letter-spacing:0.22em;text-transform:uppercase;color:var(--ink5);margin-bottom:2px;}
.mi-field-val{font-family:var(--ff);font-size:11px;font-weight:400;color:var(--ink3);}
.mi-actions{display:flex;gap:7px;margin-top:12px;}
.mi-btn{flex:1;padding:7px;background:var(--bg2);border:1px solid var(--brd);font-family:var(--ff);font-size:7.5px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--ink4);cursor:pointer;text-align:center;transition:all 0.15s;}
.mi-btn:hover{background:var(--ink);color:var(--sur);border-color:var(--ink);}
.mi-btn.grn-btn{background:var(--gr2);color:var(--grn);border-color:rgba(31,122,74,0.2);}
.mi-btn.grn-btn:hover{background:var(--grn);color:#FFF;}
.mi-btn.red-btn{background:var(--rd2);color:var(--red);border-color:rgba(192,57,43,0.2);}
.mi-btn.red-btn:hover{background:var(--red);color:#FFF;}

/* MEGA CHECKIN BTN */
.mega-btn{
  margin:16px 20px; padding:20px;
  background:var(--ink); display:flex; align-items:center; gap:14px;
  cursor:pointer; transition:background 0.2s; border:none; width:calc(100% - 40px);
  text-align:left;
}
.mega-btn:hover{background:#222;}
.mega-btn.done{background:var(--grn);}
.mega-btn.loading{background:var(--amb);}
.mega-ico{font-size:28px;flex-shrink:0;}
.mega-label{font-family:var(--ff);font-size:13px;font-weight:700;color:#FFF;letter-spacing:0.02em;}
.mega-sub{font-family:var(--ff);font-size:9px;font-weight:300;color:rgba(255,255,255,0.5);margin-top:2px;}

/* ══ CRISE ══ */
.crise-tabs{display:flex;padding:14px 20px 0;border-bottom:1px solid var(--brd);gap:0;}
.ctab{flex:1;padding:9px 4px;background:none;border:none;cursor:pointer;font-family:var(--ff);font-size:7.5px;font-weight:600;letter-spacing:0.18em;text-transform:uppercase;color:var(--ink5);border-bottom:2px solid transparent;margin-bottom:-1px;transition:color 0.2s;}
.ctab.active{color:var(--red);border-bottom-color:var(--red);}
.crise-form{padding:20px;}
.sev-row{display:flex;gap:8px;margin-top:4px;}
.sev-btn{flex:1;padding:9px 4px;border:1.5px solid var(--brd);background:transparent;font-family:var(--ff);font-size:8.5px;font-weight:600;text-transform:uppercase;letter-spacing:0.12em;color:var(--ink4);cursor:pointer;text-align:center;transition:all 0.18s;}
.sev-btn[data-s="baixa"].active{border-color:var(--grn);color:var(--grn);background:var(--gr2);}
.sev-btn[data-s="media"].active{border-color:var(--amb);color:var(--amb);background:var(--am2);}
.sev-btn[data-s="critica"].active{border-color:var(--red);color:var(--red);background:var(--rd2);}
.ocorrencias-list{padding:0 20px;display:flex;flex-direction:column;gap:8px;margin-top:16px;}
.ocorrencia-card{background:var(--sur);border:1px solid var(--brd);padding:12px 14px;border-left:3px solid var(--brd);}
.ocorrencia-card[data-s="baixa"]{border-left-color:var(--grn);}
.ocorrencia-card[data-s="media"]{border-left-color:var(--amb);}
.ocorrencia-card[data-s="critica"]{border-left-color:var(--red);}
.oc-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:4px;}
.oc-tipo{font-family:var(--ff);font-size:10.5px;font-weight:600;color:var(--ink);}
.oc-ts{font-family:var(--ffm);font-size:8.5px;color:var(--ink5);}
.oc-pass{font-family:var(--ff);font-size:9.5px;font-weight:300;color:var(--ink4);margin-bottom:4px;}
.oc-desc{font-family:var(--ff);font-size:11px;font-weight:300;color:var(--ink3);line-height:1.45;}

/* ══ BROADCAST ══ */
.bc-tabs{display:flex;padding:14px 20px 0;border-bottom:1px solid var(--brd);gap:0;}
.bctab{flex:1;padding:9px 4px;background:none;border:none;cursor:pointer;font-family:var(--ff);font-size:7.5px;font-weight:600;letter-spacing:0.18em;text-transform:uppercase;color:var(--ink5);border-bottom:2px solid transparent;margin-bottom:-1px;transition:color 0.2s;}
.bctab.active{color:var(--gold);border-bottom-color:var(--gold);}

/* POLL */
.poll-preview{background:var(--ink);padding:18px;margin-bottom:14px;position:relative;overflow:hidden;}
.poll-preview::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at top right,rgba(184,147,90,0.1),transparent 60%);pointer-events:none;}
.pp-lbl{font-family:var(--ff);font-size:7px;font-weight:700;letter-spacing:0.3em;text-transform:uppercase;color:rgba(255,255,255,0.3);margin-bottom:8px;}
.pp-q{font-family:var(--ff);font-size:13px;font-weight:500;color:#FFF;line-height:1.4;margin-bottom:4px;}
.pp-opts{display:flex;flex-direction:column;gap:5px;margin-top:10px;}
.pp-opt{padding:7px 10px;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);font-family:var(--ff);font-size:10.5px;font-weight:300;color:rgba(255,255,255,0.7);}
.poll-results{margin-top:14px;display:flex;flex-direction:column;gap:8px;}
.pr-row{display:flex;align-items:center;gap:10px;}
.pr-lbl{font-family:var(--ff);font-size:10.5px;font-weight:300;color:var(--ink3);width:120px;flex-shrink:0;}
.pr-bar{flex:1;height:18px;background:var(--bg3);overflow:hidden;}
.pr-fill{height:100%;background:var(--gold);transition:width 0.6s var(--ease);}
.pr-n{font-family:var(--ffm);font-size:9.5px;color:var(--ink4);width:30px;text-align:right;}

/* PUSH */
.push-preview{background:var(--ink);padding:16px;margin-bottom:14px;}
.pu-app{font-family:var(--ff);font-size:7px;font-weight:700;letter-spacing:0.3em;text-transform:uppercase;color:rgba(255,255,255,0.3);margin-bottom:8px;}
.pu-title{font-family:var(--ff);font-size:13px;font-weight:600;color:#FFF;margin-bottom:4px;}
.pu-body{font-family:var(--ff);font-size:11px;font-weight:300;color:rgba(255,255,255,0.6);line-height:1.5;}
.push-hist-item{padding:10px 0;border-bottom:1px solid var(--brd);}
.phi-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:3px;}
.phi-title{font-family:var(--ff);font-size:11.5px;font-weight:500;color:var(--ink);}
.phi-ts{font-family:var(--ffm);font-size:8.5px;color:var(--ink5);}
.phi-body{font-family:var(--ff);font-size:9.5px;font-weight:300;color:var(--ink4);margin-bottom:4px;}

/* MODERATION */
.mod-grid{padding:14px 20px;display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.mod-card{background:var(--sur);border:1px solid var(--brd);overflow:hidden;position:relative;}
.mod-thumb{width:100%;aspect-ratio:1;background:var(--bg2);display:flex;align-items:center;justify-content:center;font-size:36px;position:relative;overflow:hidden;}
.mod-overlay{position:absolute;inset:0;background:rgba(14,14,13,0.55);display:flex;align-items:flex-end;padding:7px;}
.mod-sender{font-family:var(--ff);font-size:8px;font-weight:600;color:#FFF;letter-spacing:0.08em;text-shadow:0 1px 3px rgba(0,0,0,0.6);}
.mod-actions{display:flex;border-top:1px solid var(--brd);}
.mod-btn{flex:1;padding:9px;background:none;border:none;font-size:16px;cursor:pointer;transition:background 0.15s;border-right:1px solid var(--brd);}
.mod-btn:last-child{border-right:none;}
.mod-btn:hover{background:var(--bg2);}
.mod-btn.approve:hover{background:var(--gr2);}
.mod-btn.reject:hover{background:var(--rd2);}
.mod-card.approved{border-color:var(--grn);}
.mod-card.rejected{opacity:0.4;}
.mod-empty{padding:30px 20px;text-align:center;font-family:var(--ff);font-size:9.5px;font-weight:300;color:var(--ink5);}
.mod-approved-badge{position:absolute;top:6px;right:6px;background:var(--grn);color:#FFF;font-family:var(--ff);font-size:7px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;padding:2px 7px;}

/* ── NEXIA INTRO KEYFRAMES ── */
@keyframes introFadeOut{to{opacity:0;}}
@keyframes introGemIn{from{transform:scale(0.5) rotate(-10deg);opacity:0;}to{transform:scale(1) rotate(0);opacity:1;}}
@keyframes introTextIn{from{opacity:0;transform:translateY(8px);}to{opacity:1;transform:none;}}
@keyframes introBarIn{from{opacity:0;}to{opacity:1;}}
@keyframes introBarFill{from{width:0%;}to{width:100%;}}

/* ══ SOS EMERGENCY MODAL ══ */
#sos-modal{
  display:none;position:fixed;inset:0;z-index:99990;
  background:#8B0000;
  flex-direction:column;align-items:center;justify-content:center;
  padding:24px;text-align:center;
  animation:sosPulse 0.8s ease-in-out infinite alternate;
}
#sos-modal.visible{ display:flex; }
@keyframes sosPulse{from{background:#8B0000;}to{background:#C0392B;}}
.sos-modal-ring{
  width:90px;height:90px;border-radius:50%;border:3px solid rgba(255,255,255,0.5);
  display:flex;align-items:center;justify-content:center;font-size:44px;
  margin-bottom:20px;
  animation:sosRing 0.6s ease-in-out infinite alternate;
}
@keyframes sosRing{from{box-shadow:0 0 0 0 rgba(255,255,255,0.6);}to{box-shadow:0 0 0 18px rgba(255,255,255,0);}}
.sos-modal-label{
  font-family:var(--ff);font-size:9px;font-weight:700;letter-spacing:0.38em;
  text-transform:uppercase;color:rgba(255,255,255,0.7);margin-bottom:12px;
}
.sos-modal-title{
  font-family:var(--ff);font-size:1.5rem;font-weight:800;color:#FFF;
  line-height:1.2;margin-bottom:8px;letter-spacing:-0.01em;
}
.sos-modal-sub{
  font-family:var(--ff);font-size:12px;font-weight:300;
  color:rgba(255,255,255,0.75);line-height:1.5;margin-bottom:32px;
  max-width:280px;
}
.sos-modal-detail{
  background:rgba(0,0,0,0.25);border:1px solid rgba(255,255,255,0.15);
  padding:12px 18px;margin-bottom:28px;width:100%;max-width:300px;text-align:left;
}
