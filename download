            <div style="display:flex;justify-content:space-between;margin-bottom:4px">
              <span style="font-size:9px;color:rgba(255,255,255,0.3)">Embarque</span>
              <span style="font-size:9px;color:#00e5ff;font-weight:700">${pct}%</span>
            </div>
            <div style="background:rgba(255,255,255,0.08);border-radius:4px;height:4px">
              <div style="height:100%;background:linear-gradient(90deg,#00e5ff,#00e87a);width:${pct}%;border-radius:4px;transition:width 0.5s"></div>
            </div>
          </div>
        </div>

        <!-- Alertas -->
        ${d.alerts.length ? `
        <div style="margin-bottom:16px">
          <div style="font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,61,90,0.8);margin-bottom:8px">🚨 Alertas Ativos</div>
          ${d.alerts.map(a=>`
            <div style="background:rgba(255,61,90,0.08);border:1px solid rgba(255,61,90,0.2);border-radius:8px;padding:10px;margin-bottom:6px;font-size:11px;color:rgba(255,255,255,0.7)">${a.msg}</div>`).join('')}
        </div>` : ''}

        <!-- Lista passageiros -->
        <div>
          <div style="font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.3);margin-bottom:10px">Lista de Passageiros</div>
          ${d.passengers.map(p=>`
            <div style="display:flex;align-items:center;gap:10px;padding:10px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);border-radius:8px;margin-bottom:6px">
              <div style="width:32px;height:32px;border-radius:50%;background:${p.status==='sos'?'rgba(255,61,90,0.2)':'rgba(0,229,255,0.1)'};display:flex;align-items:center;justify-content:center;font-size:12px;flex-shrink:0">${p.name.charAt(0)}</div>
              <div style="flex:1;min-width:0">
                <div style="color:#fff;font-size:12px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${p.name}</div>
                <div style="color:rgba(255,255,255,0.3);font-size:10px">${p.seat} · ${p.docs}</div>
              </div>
              <div style="display:flex;flex-direction:column;align-items:flex-end;gap:3px">
                <span style="background:${statusColors[p.status]||'#64748b'}18;color:${statusColors[p.status]||'#64748b'};border-radius:20px;padding:2px 8px;font-size:8px;font-weight:700;white-space:nowrap">${p.status.toUpperCase()}</span>
                ${p.notes?`<span style="color:rgba(255,170,0,0.8);font-size:8px;max-width:100px;text-align:right;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${p.notes}</span>`:''}
              </div>
            </div>`).join('')}
        </div>
      </div>`;
  }

  // Hook G.nav para dashboard
  document.addEventListener('DOMContentLoaded', () => {
    const origNav = window.G?.nav?.bind(window.G);
    if (!origNav) return;
    const _nav = G.nav;
    G.nav = function(v, btn) {
      _nav.call(G, v, btn);
      if (v === 'dashboard') {
        const root = document.getElementById('view-root');
        if (root) setTimeout(() => renderDashboard(root), 50);
      }
    };
  });
})();
</script>
</body>
</html>
