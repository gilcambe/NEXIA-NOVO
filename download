  submitCrise() {
    const tipo = document.getElementById('crise-tipo')?.value;
    const pax  = document.getElementById('crise-pax-inp')?.value;
    const desc = document.getElementById('crise-desc')?.value?.trim();
    if (!pax)  { this.toast('⚠️ Selecione o passageiro'); return; }
    if (!desc) { this.toast('⚠️ Descreva a ocorrência'); return; }
    const tipoLabels = { documento:'📄 Perda de Documento', saude:'🩺 Emergência Médica', atraso:'⏰ Atraso', extravio:'🧳 Extravio', outro:'❓ Outro' };
    this.ocorrencias.unshift({ tipo: tipoLabels[tipo] || tipo, pax, sev: this.criseSev, desc, ts: this._now(), grupo: this.groups[this.group].label });
    this.criseTab = 'hist';
    this.render_crise(document.querySelector('#view-root > div'));
    const sevMsg = { baixa:'Baixa', media:'Média', critica:'CRÍTICA' };
    this.toast('🚨 Ocorrência [' + sevMsg[this.criseSev] + '] registrada', this.criseSev === 'critica' ? 'red' : '');
  },

  _renderCriseHist(body) {
    if (this.ocorrencias.length === 0) {
      body.innerHTML = `<div style="padding:40px 20px;text-align:center;font-family:var(--ff);font-size:9.5px;font-weight:300;color:var(--ink5)">Nenhuma ocorrência registrada ✓</div>`;
      return;
    }
    body.innerHTML = `<div class="ocorrencias-list">` +
      this.ocorrencias.map(o => `
        <div class="ocorrencia-card" data-s="${o.sev}">
          <div class="oc-head">
            <span class="oc-tipo">${o.tipo}</span>
            <span class="oc-ts">${o.ts}</span>
          </div>
          <div class="oc-pass">${o.grupo} · ${o.pax}</div>
          <div style="margin-bottom:4px">
            <span class="pill ${o.sev === 'baixa' ? 'pill-grn' : o.sev === 'media' ? 'pill-amb' : 'pill-red'}">${o.sev.toUpperCase()}</span>
          </div>
          <div class="oc-desc">${o.desc}</div>
        </div>
      `).join('') + `</div><div style="height:16px"></div>`;
  },

  // ══════════════════════════════════════════════════════════
  // BROADCAST
  // ══════════════════════════════════════════════════════════
  render_broadcast(el) {
    el.innerHTML = `
      <div class="bc-tabs">
        <button class="bctab ${this.bcTab === 'poll' ? 'active' : ''}" onclick="G.setBcTab('poll')">📊 Enquete</button>
        <button class="bctab ${this.bcTab === 'push' ? 'active' : ''}" onclick="G.setBcTab('push')">📣 Push</button>
      </div>
      <div id="bc-body"></div>
    `;
    this._renderBcBody();
  },

  setBcTab(t) {
    this.bcTab = t;
    document.querySelectorAll('.bctab').forEach(b => b.classList.toggle('active', (t === 'poll' && b.textContent.includes('Enquete')) || (t === 'push' && b.textContent.includes('Push'))));
    this._renderBcBody();
  },

  _renderBcBody() {
    const body = document.getElementById('bc-body');
    if (!body) return;
    if (this.bcTab === 'poll') this._renderPoll(body);
    else this._renderPush(body);
  },

  _renderPoll(body) {
    const grp = this.groups[this.group];
    const suggestions = grp.polls;
    const pk = this.group;
    if (!this.pollVotes[pk]) this.pollVotes[pk] = null;
    const hasVotes = !!this.pollVotes[pk];

    body.innerHTML = `
      <div style="padding:18px 20px 0">
        <div class="eyebrow" style="margin-bottom:12px">Nova Enquete · ${grp.emoji} ${grp.label}</div>

        <div style="margin-bottom:14px">
          <label class="f-lbl">Pergunta</label>
          <input class="f-inp" id="poll-q" placeholder="Ex: Almoço livre ou restaurante?" value="${suggestions[0]}">
        </div>
        <div style="margin-bottom:10px">
          <label class="f-lbl">Opção A</label>
          <input class="f-inp" id="poll-a" placeholder="Opção A" value="Restaurante do grupo 🍽">
        </div>
        <div style="margin-bottom:18px">
          <label class="f-lbl">Opção B</label>
          <input class="f-inp" id="poll-b" placeholder="Opção B" value="Almoço livre 🗺">
        </div>

        <div class="poll-preview">
          <div class="pp-lbl">Preview · Aparece no app dos passageiros</div>
          <div class="pp-q" id="pp-q">${suggestions[0]}</div>
          <div class="pp-opts">
            <div class="pp-opt" id="pp-a">Restaurante do grupo 🍽</div>
            <div class="pp-opt" id="pp-b">Almoço livre 🗺</div>
          </div>
        </div>

        <button class="btn-blk gold" style="margin-bottom:${hasVotes ? '14px' : '20px'}" onclick="G.sendPoll()">📊 Enviar Enquete para Grupo</button>

        ${hasVotes ? `
          <div class="eyebrow" style="margin-bottom:10px">Resultado Simulado</div>
          <div class="poll-results">
            <div class="pr-row">
              <span class="pr-lbl" id="res-a-lbl">Restaurante do grupo 🍽</span>
              <div class="pr-bar"><div class="pr-fill" style="width:${this.pollVotes[pk].a}%"></div></div>
              <span class="pr-n">${this.pollVotes[pk].a}%</span>
            </div>
            <div class="pr-row">
              <span class="pr-lbl" id="res-b-lbl">Almoço livre 🗺</span>
              <div class="pr-bar"><div class="pr-fill" style="width:${this.pollVotes[pk].b}%;background:var(--ink3)"></div></div>
              <span class="pr-n">${this.pollVotes[pk].b}%</span>
            </div>
          </div>
        ` : ''}

        ${this.pollHistory.filter(h => h.grupo === pk).length > 0 ? `
          <div class="eyebrow" style="margin-top:20px;margin-bottom:10px">Enviadas Anteriormente</div>
          ${this.pollHistory.filter(h => h.grupo === pk).slice(0,3).map(h => `
            <div style="padding:10px 0;border-bottom:1px solid var(--brd)">
              <div style="font-family:var(--ff);font-size:11.5px;font-weight:400;color:var(--ink)">${h.q}</div>
              <div style="font-family:var(--ffm);font-size:8.5px;color:var(--ink5);margin-top:2px">${h.ts} · 10 respostas</div>
            </div>
          `).join('')}
        ` : ''}

        <div style="height:16px"></div>
      </div>
    `;

    // live preview bindings
    const liveUpdate = () => {
      const q = document.getElementById('poll-q')?.value;
      const a = document.getElementById('poll-a')?.value;
      const b = document.getElementById('poll-b')?.value;
      if (document.getElementById('pp-q')) document.getElementById('pp-q').textContent = q || '—';
      if (document.getElementById('pp-a')) document.getElementById('pp-a').textContent = a || '—';
      if (document.getElementById('pp-b')) document.getElementById('pp-b').textContent = b || '—';
    };
    ['poll-q','poll-a','poll-b'].forEach(id => { const el = document.getElementById(id); if (el) el.addEventListener('input', liveUpdate); });
  },

  sendPoll() {
    const q = document.getElementById('poll-q')?.value?.trim();
    const a = document.getElementById('poll-a')?.value?.trim();
    const b = document.getElementById('poll-b')?.value?.trim();
    if (!q || !a || !b) { this.toast('⚠️ Preencha todos os campos'); return; }
    const pk = this.group;
    this.pollHistory.unshift({ q, a, b, ts: this._now(), grupo: pk });
    // Initialize with 0 votes — passengers vote via their app (Firestore)
    this.pollVotes[pk] = { a: 0, b: 0 };
    // Save poll to Firestore so passenger app can receive and vote
    if (window.db) {
      window.db.collection('tenants').doc('VP_AGENCIA_01')
        .collection('polls').add({
          question: q, optionA: a, optionB: b,
          group: pk, votesA: 0, votesB: 0,
          createdAt: new Date().toISOString(),
          createdBy: 'guide'
        }).catch(() => {});
    }
    this.toast('📊 Enquete enviada para ' + (this.groups[this.group]?.pax?.length || 0) + ' passageiros!');
    this._renderBcBody();
  },

  _renderPush(body) {
    const grp = this.groups[this.group];
    body.innerHTML = `
      <div style="padding:18px 20px 0">
        <div class="eyebrow" style="margin-bottom:12px">Push Notification · ${grp.emoji} ${grp.label}</div>

        <div style="margin-bottom:14px">
          <label class="f-lbl">Título</label>
          <input class="f-inp" id="push-title" placeholder="Ex: Reunião no lobby" maxlength="60" oninput="G._pushLive()">
          <div style="font-family:var(--ffm);font-size:8px;color:var(--ink5);text-align:right;margin-top:4px" id="push-title-c">0/60</div>
        </div>
        <div style="margin-bottom:18px">
          <label class="f-lbl">Mensagem</label>
          <textarea class="f-ta" id="push-body" placeholder="Corpo da notificação..." maxlength="140" style="min-height:70px" oninput="G._pushLive()"></textarea>
          <div style="font-family:var(--ffm);font-size:8px;color:var(--ink5);text-align:right;margin-top:4px" id="push-body-c">0/140</div>
        </div>

        <div class="push-preview">
          <div class="pu-app">VIAJANTE PRO — ${grp.label.toUpperCase()}</div>
          <div class="pu-title" id="pu-title-prev">Título aqui</div>
          <div class="pu-body" id="pu-body-prev">Mensagem para o grupo aparece aqui.</div>
        </div>

        <div style="padding:10px 14px;background:var(--bg2);border:1px solid var(--brd);margin-bottom:14px;display:flex;align-items:center;gap:9px">
          <span style="font-size:14px">👥</span>
          <span style="font-family:var(--ff);font-size:10.5px;font-weight:400;color:var(--ink3)">Enviar para ${grp.pax.length} passageiros · ${grp.label}</span>
        </div>

        <button class="btn-blk" style="margin-bottom:20px" onclick="G.sendPush()">📣 Enviar Push Agora</button>

        ${this.pushHistory.filter(h => h.grupo === this.group).length > 0 ? `
          <div class="eyebrow" style="margin-bottom:10px">Histórico de Envios</div>
          ${this.pushHistory.filter(h => h.grupo === this.group).slice(0,5).map(h => `
            <div class="push-hist-item">
              <div class="phi-head"><span class="phi-title">${h.title}</span><span class="phi-ts">${h.ts}</span></div>
              <div class="phi-body">${h.body}</div>
              <span class="pill pill-grn">✓ Enviado · ${grp.pax.length} pessoas</span>
            </div>
          `).join('')}
        ` : ''}

        <div style="height:16px"></div>
      </div>
    `;
  },

  _pushLive() {
    const t = document.getElementById('push-title')?.value || '';
    const b = document.getElementById('push-body')?.value  || '';
    const tc = document.getElementById('push-title-c');
    const bc = document.getElementById('push-body-c');
    const tp = document.getElementById('pu-title-prev');
    const bp = document.getElementById('pu-body-prev');
    if (tc) tc.textContent = t.length + '/60';
    if (bc) bc.textContent = b.length + '/140';
    if (tp) tp.textContent = t || 'Título aqui';
    if (bp) bp.textContent = b || 'Mensagem para o grupo aparece aqui.';
  },

  sendPush() {
    const title = document.getElementById('push-title')?.value?.trim();
    const body  = document.getElementById('push-body')?.value?.trim();
    if (!title) { this.toast('⚠️ Adicione um título'); return; }
    if (!body)  { this.toast('⚠️ Adicione a mensagem'); return; }

    const grp = this.groups[this.group];
    this.pushHistory.unshift({ title, body, ts: this._now(), grupo: this.group });

    // ── 6. Push: .add() real na coleção notifications ──────────────
    // Envia um documento por passageiro para o onSnapshot do app detectar
    const _tryPush = () => {
      if (typeof NEXIA !== 'undefined' && NEXIA._ready && NEXIA.db) {
        const db        = NEXIA.db;
        const tenantRef = db.collection('tenants').doc('VP_AGENCIA_01');
        const paxList   = grp.pax || [];
        const ts        = typeof firebase !== 'undefined'
                            ? firebase.firestore.FieldValue.serverTimestamp()
                            : new Date();

        // Broadcast: um documento de notificação por passageiro
        const batch = db.batch();
        paxList.forEach(p => {
          const ref = tenantRef.collection('notifications').doc();
          batch.set(ref, {
            to:        String(this.group),       // tripKey = passenger ID
            paxId:     String(p.id),
            title:     title,
            body:      body,
            grupo:     this.group,
            grupoLabel: grp.label || '',
            read:      false,
            sentAt:    ts,
            sentBy:    'guia',
            type:      'broadcast',
          });
        });
        // Também grava no nível do grupo para histórico
        tenantRef.collection('trips').doc(this.group)
          .collection('broadcasts').add({
            title, body,
            grupo:     this.group,
            grupoLabel: grp.label || '',
            paxCount:  paxList.length,
            sentAt:    ts,
            sentBy:    'guia',
          }).catch(e => console.warn('[broadcast log]', e));

        batch.commit()
          .then(() => G.toast('📣 Push enviado para ' + paxList.length + ' passageiros!', 'grn'))
          .catch(e => {
            console.warn('[sendPush batch]', e);
            G.toast('📣 Push enviado (local) para ' + paxList.length + ' pessoas!', 'grn');
          });
      } else {
        G.toast('📣 Push enfileirado — enviando quando Firestore conectar…');
        setTimeout(_tryPush, 800);
      }
    };
    _tryPush();

    document.getElementById('push-title').value = '';
    document.getElementById('push-body').value  = '';
    this._pushLive();
    this._renderBcBody();
  },

  // ══════════════════════════════════════════════════════════
  // MURAL (MODERAÇÃO)
  // ══════════════════════════════════════════════════════════
  render_mural(el) {
    const grp = this.groups[this.group];
    const photos = this.muralState[this.group] || [];
    const pending  = photos.filter(p => p.status === 'pending').length;
    const approved = photos.filter(p => p.status === 'approved').length;

    el.innerHTML = `
      <div class="sec" style="padding-bottom:12px">
        <div class="eyebrow" style="margin-bottom:4px">Moderação de Conteúdo</div>
        <div style="font-family:var(--ffs);font-size:1.4rem;color:var(--ink);margin-bottom:2px">Mural do Grupo</div>
        <div style="font-family:var(--ff);font-size:9.5px;font-weight:300;color:var(--ink4)">${grp.emoji} ${grp.label}</div>
      </div>

      <div style="display:flex;gap:8px;padding:0 20px 14px">
        <div style="flex:1;padding:10px 14px;background:var(--am2);border:1px solid rgba(181,98,10,0.2)">
          <div style="font-family:var(--ffm);font-size:1.3rem;color:var(--amb)">${pending}</div>
          <div style="font-family:var(--ff);font-size:7.5px;font-weight:600;letter-spacing:0.18em;text-transform:uppercase;color:var(--amb);margin-top:2px">Pendentes</div>
        </div>
        <div style="flex:1;padding:10px 14px;background:var(--gr2);border:1px solid rgba(31,122,74,0.2)">
          <div style="font-family:var(--ffm);font-size:1.3rem;color:var(--grn)">${approved}</div>
          <div style="font-family:var(--ff);font-size:7.5px;font-weight:600;letter-spacing:0.18em;text-transform:uppercase;color:var(--grn);margin-top:2px">Aprovadas</div>
        </div>
        <div style="flex:1;padding:10px 14px;background:var(--bg2);border:1px solid var(--brd)">
          <div style="font-family:var(--ffm);font-size:1.3rem;color:var(--ink)">${photos.length}</div>
          <div style="font-family:var(--ff);font-size:7.5px;font-weight:600;letter-spacing:0.18em;text-transform:uppercase;color:var(--ink4);margin-top:2px">Total</div>
        </div>
      </div>

      ${pending > 0 ? `
        <div style="padding:0 20px 8px">
          <div class="eyebrow" style="margin-bottom:8px">⏳ Aguardando Aprovação</div>
        </div>
      ` : ''}

      <div class="mod-grid">
        ${photos.length === 0 ? `<div class="mod-empty" style="grid-column:1/-1">Nenhuma foto enviada ainda</div>` :
          photos.map(p => this._modCard(p)).join('')}
      </div>

      <div style="padding:0 20px 8px;margin-top:4px">
        <div class="eyebrow" style="margin-bottom:8px">Ações em Massa</div>
        <div style="display:flex;gap:8px">
          <button class="btn-blk grn" style="font-size:7.5px" onclick="G.approveAll()">✅ Aprovar Todas</button>
          <button class="btn-blk red" style="font-size:7.5px" onclick="G.rejectAll()">🗑 Rejeitar Pendentes</button>
        </div>
      </div>

      <div style="height:20px"></div>
    `;
  },

  _modCard(p) {
    const isApproved = p.status === 'approved';
    const isRejected = p.status === 'rejected';
    return `
      <div class="mod-card ${isApproved ? 'approved' : ''} ${isRejected ? 'rejected' : ''}" id="mod-${p.id}">
        ${isApproved ? `<div class="mod-approved-badge">✓ Aprovado</div>` : ''}
        <div class="mod-thumb">
          <span style="font-size:3rem">${p.emoji}</span>
          <div class="mod-overlay">
            <span class="mod-sender">${p.sender}</span>
          </div>
        </div>
        <div style="padding:6px 8px;font-family:var(--ff);font-size:8.5px;font-weight:300;color:var(--ink3);line-height:1.35">${p.caption}</div>
        <div class="mod-actions">
          <button class="mod-btn approve" title="Aprovar" onclick="G.moderatePhoto('${p.id}','approved')">✅</button>
          <button class="mod-btn reject"  title="Rejeitar" onclick="G.moderatePhoto('${p.id}','rejected')">🗑</button>
        </div>
      </div>
    `;
  },

  moderatePhoto(id, action) {
    const photos = this.muralState[this.group];
    const photo  = photos.find(p => p.id === id);
    if (!photo) return;
    photo.status = action;

    // ── 5. Mural: .update() no Firestore ────────────────────────
    const _tryUpdate = () => {
      if (typeof NEXIA !== 'undefined' && NEXIA._ready && NEXIA.db) {
        NEXIA.db.collection('tenants').doc('VP_AGENCIA_01')
          .collection('trips').doc(this.group)
          .collection('mural').doc(id)
          .update({ status: action, moderatedAt: firebase.firestore.FieldValue.serverTimestamp(), moderatedBy: 'guia' })
          .catch(e => console.warn('[moderatePhoto]', e));
      }
    };
    _tryUpdate();

    const msg = action === 'approved' ? '✅ Foto aprovada — publicada no mural!' : '🗑 Foto rejeitada';
    this.toast(msg, action === 'approved' ? 'grn' : 'red');
    this.render_mural(document.querySelector('#view-root > div'));
  },

  approveAll() {
    const photos  = this.muralState[this.group];
    const pending = photos.filter(p => p.status === 'pending');
    if (pending.length === 0) { this.toast('Nenhuma pendente'); return; }
    pending.forEach(p => { p.status = 'approved'; });

    // Batch update no Firestore
    const _tryBatch = () => {
      if (typeof NEXIA !== 'undefined' && NEXIA._ready && NEXIA.db) {
        const db      = NEXIA.db;
        const colRef  = db.collection('tenants').doc('VP_AGENCIA_01')
                          .collection('trips').doc(this.group).collection('mural');
        const batch   = db.batch();
        pending.forEach(p => {
          batch.update(colRef.doc(p.id), {
            status: 'approved',
            moderatedAt: firebase.firestore.FieldValue.serverTimestamp(),
            moderatedBy: 'guia_bulk',
          });
        });
        batch.commit().catch(e => console.warn('[approveAll batch]', e));
      }
    };
    _tryBatch();

    this.toast('✅ ' + pending.length + ' fotos aprovadas!', 'grn');
    this.render_mural(document.querySelector('#view-root > div'));
  },

  rejectAll() {
    const photos  = this.muralState[this.group];
    const pending = photos.filter(p => p.status === 'pending');
    if (pending.length === 0) { this.toast('Nenhuma pendente'); return; }
    pending.forEach(p => { p.status = 'rejected'; });

    // Batch update no Firestore
    const _tryBatch = () => {
      if (typeof NEXIA !== 'undefined' && NEXIA._ready && NEXIA.db) {
        const db      = NEXIA.db;
        const colRef  = db.collection('tenants').doc('VP_AGENCIA_01')
                          .collection('trips').doc(this.group).collection('mural');
        const batch   = db.batch();
        pending.forEach(p => {
          batch.update(colRef.doc(p.id), {
            status: 'rejected',
            moderatedAt: firebase.firestore.FieldValue.serverTimestamp(),
            moderatedBy: 'guia_bulk',
          });
        });
        batch.commit().catch(e => console.warn('[rejectAll batch]', e));
      }
    };
    _tryBatch();

    this.toast('🗑 ' + pending.length + ' fotos rejeitadas', 'red');
    this.render_mural(document.querySelector('#view-root > div'));
  },

  // ── TOAST ─────────────────────────────────────────────────
  toast(msg, type, dur) {
    dur = dur || 2800;
    const root = document.getElementById('toast-root');
    if (!root) return;
    const el = document.createElement('div');
    el.className = 'toast' + (type === 'red' ? ' red' : type === 'grn' ? ' grn' : '');
    el.textContent = msg;
    root.appendChild(el);
    setTimeout(() => { el.style.opacity = '0'; el.style.transition = 'opacity .25s'; setTimeout(() => el.remove(), 260); }, dur);
  },
};

G.init();

// ══════════════════════════════════════════════════════════════
// ✅ FIREBASE BOOTSTRAP — delegado ao G._startFirestore()
// O G.init() já chama G._startFirestore() que inicializa tudo.
// Este bloco garante VP_SOS/VP_PASSENGERS se o NEXIA demorar.
// ══════════════════════════════════════════════════════════════
(function initGuideFirebase() {
  const tryInit = () => {
    if (typeof NEXIA === 'undefined' || !NEXIA._ready || !NEXIA.db) {
      setTimeout(tryInit, 500); return;
    }
    window._vpGuideDb = NEXIA.db;
    if (typeof VP_SOS        !== 'undefined' && !VP_SOS._unsub)        VP_SOS.startListener();
    if (typeof VP_PASSENGERS !== 'undefined' && !VP_PASSENGERS._unsub) VP_PASSENGERS.startListener();
    if (typeof VP_THEME      !== 'undefined' && !VP_THEME._unsub)      VP_THEME.startListener();
    if (typeof VP_MODULES    !== 'undefined' && !VP_MODULES._unsub)    VP_MODULES.startListener();
  };
  tryInit();
})();

// ══════════════════════════════════════════════════════════════
// ✅ VP_SOS — Receptor SOS em Tempo Real + Modal Extremo
// ══════════════════════════════════════════════════════════════
const VP_SOS = {
  _unsub: null,
  _activeAlerts: [],
  _currentAlertId: null,

  startListener() {
    const db = window._vpGuideDb;
    if (!db) { setTimeout(() => this.startListener(), 800); return; }
    if (this._unsub) return;

    this._unsub = db.collection('tenants').doc('VP_AGENCIA_01')
      .collection('alerts')
      .where('status', '==', 'active')
      .onSnapshot(snap => {
        const prev = this._activeAlerts.length;
        this._activeAlerts = snap.docs.map(d => ({ id: d.id, ...d.data() }));
        const count = this._activeAlerts.length;

        this._updateBadge(count);

        if (count > 0 && (count > prev || !document.getElementById('sos-modal').classList.contains('visible'))) {
          const alert = this._activeAlerts[0];
          this._showModal(alert);
          this._markSOSOnManifesto(alert);
        }
        if (count === 0) {
          this._hideModal();
        }
      }, err => console.warn('[VP_SOS onSnapshot]', err));
  },

  _updateBadge(count) {
    let badge = document.getElementById('vp-sos-badge');
    if (!badge) {
      badge = document.createElement('div');
      badge.id = 'vp-sos-badge';
      badge.style.cssText = 'position:fixed;top:52px;right:10px;z-index:9000;background:#C0392B;color:#FFF;font-family:\'Sora\',sans-serif;font-size:8px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;padding:4px 10px;cursor:pointer;animation:sosblink 1.2s ease-in-out infinite;display:none';
      badge.onclick = () => VP_SOS._showModal(this._activeAlerts[0]);
      document.getElementById('shell').appendChild(badge);
    }
    if (count > 0) {
      badge.textContent = '🆘 SOS · ' + count;
      badge.style.display = 'block';
    } else {
      badge.style.display = 'none';
    }
  },

  _showModal(alert) {
    if (!alert) return;
    this._currentAlertId = alert.id;
    const passengerName = alert.passenger || alert.nome || alert.passengerName || 'Passageiro';
    const grupo         = alert.group   || alert.grupo || 'VP_AGENCIA_01';
    const ts            = alert.createdAt?.toDate ? alert.createdAt.toDate().toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' }) : new Date().toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' });

    document.getElementById('sos-modal-title').textContent = '🆘 EMERGÊNCIA: ' + passengerName + ' acionou o SOS!';
    document.getElementById('sos-modal-sub').textContent   = 'Verifique imediatamente a localização de ' + passengerName + ' e entre em contato.';
    document.getElementById('sos-detail-pax').textContent  = passengerName;
    document.getElementById('sos-detail-grupo').textContent = grupo;
    document.getElementById('sos-detail-time').textContent = ts;
    document.getElementById('sos-detail-id').textContent   = alert.id?.slice(0, 8) + '…';
    document.getElementById('sos-modal').classList.add('visible');

    if (navigator.vibrate) navigator.vibrate([400, 200, 400, 200, 800]);
    this._flashTitle('🆘 SOS ATIVO!');
  },

  _hideModal() {
    document.getElementById('sos-modal').classList.remove('visible');
    this._currentAlertId = null;
    document.title = 'Viajante Pro — Guia Operacional';
  },

  dismiss() {
    document.getElementById('sos-modal').classList.remove('visible');
    G.toast('⚠️ SOS ainda ativo — alerta visível na barra', 'red');
  },

  async resolve() {
    const db = window._vpGuideDb;
    const id = this._currentAlertId;
    if (!db || !id) { G.toast('Nenhum alerta selecionado', 'red'); return; }
    const btn = document.getElementById('sos-resolve-btn');
    if (btn) { btn.textContent = 'Resolvendo…'; btn.disabled = true; }
    try {
      await db.collection('tenants').doc('VP_AGENCIA_01').collection('alerts').doc(id)
        .update({ status: 'resolved', resolvedAt: firebase.firestore.FieldValue.serverTimestamp() });
      this._hideModal();
      G.toast('✅ SOS marcado como resolvido!', 'grn');
    } catch(e) {
      G.toast('Erro ao resolver: ' + e.message, 'red');
      if (btn) { btn.textContent = '✅ MARCAR COMO RESOLVIDO'; btn.disabled = false; }
    }
  },

  _markSOSOnManifesto(alert) {
    const paxName = alert.passenger || '';
    if (!paxName || !window.G) return;
    // Marca SOS no groups ao vivo (Firestore-backed)
    Object.values(G.groups).forEach(grp => {
      if (grp.pax) grp.pax.forEach(p => { if (p.name === paxName) p.sos = true; });
    });
    // Também marca no SEED_GROUPS para consistência offline
    Object.values(G.SEED_GROUPS).forEach(grp => {
      if (grp.pax) grp.pax.forEach(p => { if (p.name === paxName) p.sos = true; });
    });
    if (G.currentView === 'manifesto') {
      const root = document.querySelector('#view-root > div');
      if (root) G.render_manifesto(root);
    }
  },

  _flashTitle(msg) {
    let on = true;
    const orig = 'Viajante Pro — Guia Operacional';
    const iv = setInterval(() => {
      document.title = on ? msg : orig;
      on = !on;
      if (!this._activeAlerts.length) { clearInterval(iv); document.title = orig; }
    }, 900);
  }
};

// ══════════════════════════════════════════════════════════════
// ✅ VP_PASSENGERS — Aba Passageiros com Check-in em Tempo Real
// ══════════════════════════════════════════════════════════════
const VP_PASSENGERS = {
  _unsub: null,
  _passengers: [],
  _loading: true,
  _currentGroup: null,

  startListener(groupKey) {
    const db = window._vpGuideDb;
    if (!db) { setTimeout(() => this.startListener(groupKey), 800); return; }
    const gk = groupKey || G.group || 'disney';

    // Se já está escutando o mesmo grupo, não refaz
    if (this._unsub && this._currentGroup === gk) return;
    // Cancela listener anterior se mudou de grupo
    if (this._unsub) { this._unsub(); this._unsub = null; }

    this._currentGroup = gk;
    this._loading = true;
    this._render();

    // ── 1. onSnapshot na coleção passengers do grupo atual ─────────
    this._unsub = db.collection('tenants').doc('VP_AGENCIA_01')
      .collection('trips').doc(gk)
      .collection('passengers')
      .onSnapshot(snap => {
        this._loading = false;
        if (snap.empty) {
          this._useFallback();
        } else {
          this._passengers = snap.docs.map(d => ({ id: d.id, ...d.data() }));
        }
        this._render();
        this._updateProgress();
      }, err => {
        this._loading = false;
        console.warn('[VP_PASSENGERS]', err);
        this._useFallback();
      });
  },

  _useFallback() {
    // Usa SEED_GROUPS como fonte de verdade offline
    const grp = G.SEED_GROUPS[G.group] || G.groups[G.group];
    if (!grp) return;
    this._passengers = (grp.pax || []).map(p => ({
      id: 'local_' + p.id, name: p.name, room: p.room, flight: p.flight,
      checkinStatus: G.checkinState[G.group]?.[p.id] ? 'checkedin' : 'pending',
      nexions: 0, tags: p.tags, color: p.bg, initials: p.avatar
    }));
    this._render();
  },

  _render() {
    if (G.currentView !== 'passengers') return;
    const root = document.querySelector('#view-root > div');
    if (!root) return;
    const total     = this._passengers.length;
    const checkedIn = this._passengers.filter(p => p.checkinStatus === 'checkedin').length;
    const sosCount = this._passengers.filter(p => p.sosActive).length;

    root.innerHTML = `
      <div class="pax-header">
        <div>
          <div class="eyebrow" style="margin-bottom:2px">Check-in · Tempo Real</div>
          <div style="font-family:var(--ffs);font-style:italic;font-size:1.1rem;color:var(--ink)">Passageiros</div>
        </div>
        <button onclick="VP_PASSENGERS._syncAll()" style="padding:5px 12px;border:1px solid var(--brd);background:var(--bg2);font-family:var(--ff);font-size:7.5px;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;color:var(--ink4);cursor:pointer">↺ Sync</button>
      </div>
      <div class="pax-stats">
        <div class="pax-stat"><div class="pax-stat-val">${total}</div><div class="pax-stat-lbl">Total</div></div>
        <div class="pax-stat"><div class="pax-stat-val" style="color:var(--grn)">${checkedIn}</div><div class="pax-stat-lbl">Check-in</div></div>
        <div class="pax-stat"><div class="pax-stat-val" style="color:${total - checkedIn > 0 ? 'var(--amb)' : 'var(--ink5)'}">${total - checkedIn}</div><div class="pax-stat-lbl">Pendentes</div></div>
        ${sosCount > 0 ? `<div class="pax-stat"><div class="pax-stat-val" style="color:var(--red)">${sosCount}</div><div class="pax-stat-lbl" style="color:var(--red)">SOS</div></div>` : ''}
      </div>
      ${this._loading ? `<div class="pax-loading"><div class="pax-loading-ring"></div>Conectando ao Firestore…</div>` :
        (total === 0 ? `<div class="pax-loading">Nenhum passageiro encontrado.</div>` : `<div class="pax-list">${this._passengers.map(p => this._paxCard(p)).join('')}</div>`)
      }
    `;
  },

  _paxCard(p) {
    const isChecked = p.checkinStatus === 'checkedin';
    const hasSOS    = p.sosActive === true;
    const initials  = p.initials || (p.name ? p.name.split(' ').slice(0,2).map(w=>w[0]).join('') : '?');
    const color     = p.color || '#1A4080';
    const nexions   = p.nexions || 0;

    return `
      <div class="pax-card ${isChecked ? 'checkedin' : ''} ${hasSOS ? 'sos-alert' : ''}">
        <div class="pax-card-row">
          <div class="pax-av" style="background:${color}">${initials}</div>
          <div class="pax-info">
            <div class="pax-name">${p.name || '—'}</div>
            <div class="pax-sub">${p.room ? 'Quarto ' + p.room : ''} ${p.flight ? '· Voo ' + p.flight : ''}</div>
            ${nexions > 0 ? `<div class="pax-nexions">💎 ${nexions.toLocaleString('pt-BR')} Néxions</div>` : ''}
          </div>
          <button class="pax-checkin-btn ${isChecked ? 'done' : ''} ${hasSOS ? 'sos-btn' : ''}" onclick="VP_PASSENGERS.toggleCheckin('${p.id}','${(p.name||'').replace(/'/g,'\\\'')}')">
            ${hasSOS ? '🆘 SOS' : isChecked ? '✓ OK' : 'Check-in'}
          </button>
        </div>
      </div>
    `;
  },

  async toggleCheckin(paxId, paxName) {
    const db  = window._vpGuideDb;
    const pax = this._passengers.find(p => p.id === paxId);
    if (!pax) return;
    const newStatus = pax.checkinStatus === 'checkedin' ? 'pending' : 'checkedin';

    // Optimistic update
    pax.checkinStatus = newStatus;
    this._render();
    this._updateProgress();

    if (db && !paxId.startsWith('local_')) {
      try {
        // ── 3. .update() real no Firestore — caminho correto por grupo ──
        await db.collection('tenants').doc('VP_AGENCIA_01')
          .collection('trips').doc(G.group)
          .collection('passengers').doc(paxId)
          .set({
            checkinStatus: newStatus,
            checkinAt: newStatus === 'checkedin' ? firebase.firestore.FieldValue.serverTimestamp() : null,
            checkinBy: 'guia'
          }, { merge: true });
        // Sincroniza checkinState local
        G.checkinState[G.group][parseInt(paxId) || paxId] = newStatus === 'checkedin';
        G._updateProgress();
        G.toast(newStatus === 'checkedin'
          ? '✅ ' + paxName + ' — Check-in confirmado!'
          : '↩ ' + paxName + ' — Check-in removido',
          newStatus === 'checkedin' ? 'grn' : '');
      } catch(e) {
        G.toast('Erro ao salvar: ' + e.message, 'red');
        // Rollback
        pax.checkinStatus = newStatus === 'checkedin' ? 'pending' : 'checkedin';
        this._render();
      }
    } else {
      G.checkinState[G.group][parseInt(paxId.replace('local_',''))] = newStatus === 'checkedin';
      G._updateProgress();
      G.toast(newStatus === 'checkedin'
        ? '✅ ' + paxName + ' embarcou (local)'
        : '↩ Removido (local)', 'grn');
    }
  },

  async _syncAll() {
    G.toast('↺ Sincronizando com Firestore…');
    if (this._unsub) { this._unsub(); this._unsub = null; }
    this._loading = true;
    this._currentGroup = null;
    this._render();
    this.startListener(G.group);
  },

  _updateProgress() {
    const total     = this._passengers.length;
    const checkedIn = this._passengers.filter(p => p.checkinStatus === 'checkedin').length;
    if (total === 0) return;
    const pct = Math.round((checkedIn / total) * 100);
    const countEl = document.getElementById('ps-count');
    const fillEl  = document.getElementById('ps-fill');
    if (countEl) countEl.textContent = checkedIn + '/' + total + ' (FS)';
    if (fillEl)  fillEl.style.width  = pct + '%';
  }
};

