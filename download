// VP_MODULES — Reatividade de Módulos em Tempo Real
// ══════════════════════════════════════════════════════════════
const VP_MODULES = {
  _unsub: null,
  startListener() {
    const tryStart = () => {
      const db = window._vpGuideDb;
      if (!db) { setTimeout(tryStart, 800); return; }
      if (this._unsub) return;
      this._unsub = db.collection('tenants').doc('VP_AGENCIA_01').collection('modules')
        .onSnapshot(snap => {
          snap.forEach(doc => {
            const mod    = doc.id;
            const active = doc.data().status === 'active';
            document.querySelectorAll('[data-module="' + mod + '"]').forEach(el => {
              el.style.display = active ? '' : 'none';
            });
            if (mod === 'sos' || mod === 'chat') {
              document.querySelectorAll('.nb[data-v="' + mod + '"], .nb.crise-btn[data-v="crise"]').forEach(el => {
                if (mod === 'sos') el.style.display = active ? '' : 'none';
              });
              if (mod === 'chat') {
                document.querySelectorAll('[data-module="broadcast"], .nb[data-v="broadcast"]').forEach(el => {
                  el.style.display = active ? '' : 'none';
                });
              }
            }
          });
        }, err => console.warn('[VP_MODULES]', err));
    };
    tryStart();
  }
};

