  togglePax(id) {
    const key = this.group + '_' + id;
    this.openPax[key] = !this.openPax[key];
    this.render_manifesto(document.querySelector('#view-root > div'));
  },

  toggleCheckin(id) {
    const state   = this.checkinState[this.group];
    const newVal  = !state[id];
    state[id]     = newVal;
    const grp     = this.groups[this.group];
    const p       = grp.pax.find(x => x.id === id);
    if (!p) return;
    const newStatus = newVal ? 'checkedin' : 'pending';

    // ── 3. Check-in real: .update() no Firestore ──────────────────
    const _tryUpdate = () => {
      if (typeof NEXIA !== 'undefined' && NEXIA._ready && NEXIA.db) {
        NEXIA.db.collection('tenants').doc('VP_AGENCIA_01')
          .collection('trips').doc(this.group)
          .collection('passengers').doc(String(id))
          .update({
            checkinStatus: newStatus,
            checkinAt:     newStatus === 'checkedin'
                             ? firebase.firestore.FieldValue.serverTimestamp()
                             : null,
            checkinBy: 'guia',
          })
          .catch(e => console.warn('[toggleCheckin] Firestore error:', e));
      }
    };
    _tryUpdate();

    this._updateProgress();
    this.toast(newVal ? '✅ ' + p.name + ' embarcou' : '↩ ' + p.name + ' removido', 'grn');
    this.render_manifesto(document.querySelector('#view-root > div'));
  },

  checkInAll() {
    const grp     = this.groups[this.group];
    const state   = this.checkinState[this.group];
    const allDone = grp.pax.every(p => state[p.id]);
    if (allDone) { this.toast('✅ Todos já embarcados!', 'grn'); return; }
    const btn = document.getElementById('mega-btn');
    if (btn) { btn.classList.add('loading'); btn.querySelector('.mega-label').textContent = 'Processando…'; }

    // ── 3. Embarcar Todos: batch .update() no Firestore ───────────
    const pending = grp.pax.filter(p => !state[p.id]);
    const _tryBatch = () => {
      if (typeof NEXIA !== 'undefined' && NEXIA._ready && NEXIA.db) {
        const db       = NEXIA.db;
        const paxColRef = db.collection('tenants').doc('VP_AGENCIA_01')
                           .collection('trips').doc(this.group)
                           .collection('passengers');
        // Firestore max 500/batch — dividir se necessário
        const chunks = [];
        for (let i = 0; i < pending.length; i += 400) chunks.push(pending.slice(i, i + 400));
        chunks.forEach(chunk => {
          const batch = db.batch();
          chunk.forEach(p => {
            batch.update(paxColRef.doc(String(p.id)), {
              checkinStatus: 'checkedin',
              checkinAt:     firebase.firestore.FieldValue.serverTimestamp(),
              checkinBy:     'guia_bulk',
            });
          });
          batch.commit().catch(e => console.warn('[checkInAll batch]', e));
        });
      }
    };

    // Atualiza estado local com animação progressiva
    let i = 0;
    const tick = () => {
      if (i >= grp.pax.length) {
        this._updateProgress();
        this.render_manifesto(document.querySelector('#view-root > div'));
        this.toast('✅ ' + grp.pax.length + ' passageiros embarcados!', 'grn');
        _tryBatch();
        return;
      }
      state[grp.pax[i].id] = true;
      i++;
      this._updateProgress();
      setTimeout(tick, 80);
    };
    setTimeout(tick, 400);
  },

  resetCheckin() {
    this.checkinState[this.group] = {};
    this._updateProgress();
    this.render_manifesto(document.querySelector('#view-root > div'));
    this.toast('↩ Check-ins resetados');
  },

