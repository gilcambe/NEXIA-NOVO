  // ── INIT ──────────────────────────────────────────────────
  init() {
    setInterval(() => {
      const el = document.getElementById('sbar-time');
      if (el) el.textContent = new Date().toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'});
    }, 1000);
    document.getElementById('sbar-time').textContent = this._now();

    // Pré-carrega SEED como fallback imediato (torna UI responsiva antes do Firestore)
    ['disney','paris','ces','japao'].forEach(k => {
      this.groups[k] = JSON.parse(JSON.stringify(this.SEED_GROUPS[k]));
    });

    this.setGroup('disney', document.querySelector('.grp-btn[data-g="disney"]'));
    this.nav('manifesto', document.querySelector('.nb[data-v="manifesto"]'));

    // Inicia integração Firestore após DOM pronto
    this._startFirestore();
  },

  // ── FIRESTORE BOOTSTRAP ───────────────────────────────────
  _startFirestore() {
    const _try = () => {
      if (typeof NEXIA === 'undefined' || !NEXIA._ready || !NEXIA.db) {
        setTimeout(_try, 600); return;
      }
      const db        = NEXIA.db;
      const tenantRef = db.collection('tenants').doc('VP_AGENCIA_01');

      // ── 1 & 2. MANIFESTO: onSnapshot de passengers por grupo ─────
      // Para cada grupo, escuta a subcoleção passengers e faz self-seed se vazia
      ['disney','paris','ces','japao'].forEach(groupKey => {
        const paxCol = tenantRef.collection('trips').doc(groupKey).collection('passengers');
        const unsub = paxCol.onSnapshot(snap => {
          if (snap.empty) {
            // ── Self-Seeding via batch ──────────────────────────────
            const seedPax = this.SEED_GROUPS[groupKey]?.pax || [];
            if (seedPax.length === 0) return;
            const batch = db.batch();
            seedPax.forEach(p => {
              batch.set(paxCol.doc(String(p.id)), {
                ...p,
                checkinStatus: 'pending',
                _seeded:       true,
                _seededAt:     new Date(),
              });
            });
            batch.commit().catch(e => console.warn('[Seed passengers ' + groupKey + ']', e));
            // Mantém SEED local enquanto batch processa
            if (!this.groups[groupKey]) {
              this.groups[groupKey] = JSON.parse(JSON.stringify(this.SEED_GROUPS[groupKey]));
            }
          } else {
            // ── Popula groups[groupKey].pax do Firestore ────────────
            const paxFromFS = snap.docs.map(d => {
              const data = d.data();
              return {
                id:            parseInt(d.id) || d.id,
                name:          data.name          || '',
                room:          data.room          || '',
                flight:        data.flight        || '',
                doc:           data.doc           || '',
                tags:          data.tags          || [],
                bg:            data.bg            || '#0E0E0D',
                avatar:        data.avatar        || '',
                checkinStatus: data.checkinStatus || 'pending',
                sos:           data.sos           || false,
              };
            });
            // Garante que o grupo existe antes de atribuir pax
            if (!this.groups[groupKey]) {
              this.groups[groupKey] = JSON.parse(JSON.stringify(this.SEED_GROUPS[groupKey] || {}));
            }
            this.groups[groupKey].pax = paxFromFS;

            // Sincroniza checkinState local com Firestore
            this.checkinState[groupKey] = {};
            paxFromFS.forEach(p => {
              this.checkinState[groupKey][p.id] = p.checkinStatus === 'checkedin';
            });

            // Re-renderiza se for o grupo atual
            if (groupKey === this.group) {
              this._updateProgress();
              if (this.currentView === 'manifesto') {
                this.nav('manifesto', document.querySelector('.nb[data-v="manifesto"]'));
              }
            }
          }
        }, err => console.warn('[Passengers onSnapshot ' + groupKey + ']', err));
        this._firestoreUnsubs.push(unsub);
      });

      // ── 5. MURAL: onSnapshot por grupo ─────────────────────
      ['disney','paris','ces','japao'].forEach(groupKey => {
        const muralCol = tenantRef.collection('trips').doc(groupKey).collection('mural');
        const unsub = muralCol.orderBy('createdAt','desc').onSnapshot(snap => {
          if (snap.empty) {
            // Self-seed mural com fotos do SEED
            const seedPhotos = this.muralState[groupKey] || [];
            if (seedPhotos.length > 0) {
              const batch = db.batch();
              seedPhotos.forEach(p => {
                batch.set(muralCol.doc(p.id), {
                  ...p,
                  createdAt: new Date(),
                  _seeded:   true,
                });
              });
              batch.commit().catch(e => console.warn('[Seed mural ' + groupKey + ']', e));
            }
          } else {
            // Dados reais do Firestore
            this.muralState[groupKey] = snap.docs.map(d => ({ id: d.id, ...d.data() }));
            if (groupKey === this.group && this.currentView === 'mural') {
              this.nav('mural', document.querySelector('.nb[data-v="mural"]'));
            }
          }
        }, err => console.warn('[Mural onSnapshot ' + groupKey + ']', err));
        this._firestoreUnsubs.push(unsub);
      });

      // ── VP_PASSENGERS e VP_SOS já têm seus próprios listeners ──
      // São inicializados via initGuideFirebase()
      window._vpGuideDb = db;
      if (typeof VP_SOS       !== 'undefined') VP_SOS.startListener();
      if (typeof VP_PASSENGERS !== 'undefined') VP_PASSENGERS.startListener();
      if (typeof VP_THEME      !== 'undefined') VP_THEME.startListener();
      if (typeof VP_MODULES    !== 'undefined') VP_MODULES.startListener();
    };
    _try();
  },

  // ── GROUP SELECT ──────────────────────────────────────────
  setGroup(key, btn) {
    this.group = key;
    document.querySelectorAll('.grp-btn').forEach(b => b.classList.remove('active'));
    if (btn) btn.classList.add('active');
    const grp = this.groups[key];
    document.getElementById('tb-av').textContent = grp.initials;
    this._updateProgress();
    if (this.currentView) this.nav(this.currentView);
    this.toast('🗂 Grupo: ' + grp.label);
  },

  _updateProgress() {
    const grp = this.groups[this.group];
    const state = this.checkinState[this.group];
    const done = grp.pax.filter(p => state[p.id]).length;
    const total = grp.pax.length;
    const pct = Math.round((done / total) * 100);
    document.getElementById('ps-count').textContent = done + '/' + total;
    document.getElementById('ps-fill').style.width = pct + '%';
    document.getElementById('ps-label').textContent = 'Check-in · ' + this.groups[this.group].label;
  },

