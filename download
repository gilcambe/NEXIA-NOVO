// VP_THEME — Reatividade de Design em Tempo Real
// ══════════════════════════════════════════════════════════════
const VP_THEME = {
  _unsub: null,
  startListener() {
    const tryStart = () => {
      const db = window._vpGuideDb;
      if (!db) { setTimeout(tryStart, 800); return; }
      if (this._unsub) return;
      this._unsub = db.collection('tenants').doc('VP_AGENCIA_01').collection('public_site').doc('config')
        .onSnapshot(snap => {
          if (!snap.exists) return;
          const cfg = snap.data();
          if (!cfg || !cfg.color) return;
          const hex = cfg.color.replace('#','');
          const r = parseInt(hex.substring(0,2),16);
          const g = parseInt(hex.substring(2,4),16);
          const b = parseInt(hex.substring(4,6),16);
          const rgb = r+','+g+','+b;
          const root = document.documentElement;
          root.style.setProperty('--gold',   cfg.color);
          root.style.setProperty('--accent', cfg.color);
          root.style.setProperty('--blu',    cfg.color);
          root.style.setProperty('--gold2',  'rgba('+rgb+',0.14)');
          root.style.setProperty('--blu2',   'rgba('+rgb+',0.08)');
          try { localStorage.setItem('vp_guide_theme', JSON.stringify(cfg)); } catch(e){}
          if (window.G && G.toast) G.toast('🎨 Tema atualizado pelo Admin');
        }, err => console.warn('[VP_THEME]', err));
    };
    tryStart();
  }
};

