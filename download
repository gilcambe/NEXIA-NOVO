<script>
// @ts-nocheck
(function(){
  function _applyColor(cfg) {
    var color = cfg.color || cfg.cor;
    if (!color) return;
    var hex = color.replace('#','');
    var r=parseInt(hex.substring(0,2),16), g=parseInt(hex.substring(2,4),16), b=parseInt(hex.substring(4,6),16);
    var rgb = r+','+g+','+b;
    var root = document.documentElement;
    root.style.setProperty('--gold',  color);
    root.style.setProperty('--g2',    'rgba('+rgb+',0.10)');
    root.style.setProperty('--brand', color);
    root.style.setProperty('--blu',   color);
    root.style.setProperty('--blu2',  'rgba('+rgb+',0.08)');
    document.querySelectorAll('[data-brand-name]').forEach(function(el) {
      if (cfg.brandName) el.textContent = cfg.brandName;
    });
    window._NEXIA_BRAND = cfg;
  }

  // Aplica imediatamente do localStorage
  var raw = null;
  try { raw = localStorage.getItem('nexia_theme_vp_guide'); } catch(e){}
  if (!raw) { try { raw = localStorage.getItem('vp_master_cms_guide'); } catch(e){} }
  if (!raw) { try { raw = localStorage.getItem('nexia_theme_vp_passenger'); } catch(e){} }
  if (raw) { try { _applyColor(JSON.parse(raw)); } catch(e){} }

  // Após DOM pronto: ativa Firestore onSnapshot para updates instantâneos
  document.addEventListener('DOMContentLoaded', function() {
    var _try = function() {
      if (typeof NexiaTheme === 'undefined') { setTimeout(_try, 400); return; }
      NexiaTheme.watchBrand('vp', 'guide', function(cfg) {
        if (cfg) _applyColor(cfg);
      });
    };
    _try();
  });
})();
</script>
