// ── CALCULADORA DE ROI ───────────────────────────────────────────
window.VP_ROI = {
  calc() {
    const viagens   = parseInt(document.getElementById('roi-viagens')?.value)  || 10;
    const ticket    = parseInt(document.getElementById('roi-ticket')?.value)   || 5000;
    const comissao  = parseInt(document.getElementById('roi-comissao')?.value) || 10;
    const horas     = parseInt(document.getElementById('roi-horas')?.value)    || 40;
    const custoHora = 80; // custo médio hora/admin

    const receitaAnual   = viagens * ticket * 12;
    const comissaoAnual  = receitaAnual * (comissao/100);
    const custoManual    = horas * custoHora * 12;
    const nexiaCost      = 5976; // R$498/mês
    const economia       = custoManual - nexiaCost;
    const roi            = Math.round(((comissaoAnual + economia) / nexiaCost) * 100);

    const el = id => document.getElementById(id);
    if(el('roi-result-receita'))  el('roi-result-receita').textContent  = 'R$'+receitaAnual.toLocaleString('pt-BR');
    if(el('roi-result-comissao')) el('roi-result-comissao').textContent = 'R$'+comissaoAnual.toLocaleString('pt-BR');
    if(el('roi-result-economia')) el('roi-result-economia').textContent = 'R$'+economia.toLocaleString('pt-BR');
    if(el('roi-result-roi'))      el('roi-result-roi').textContent      = roi+'%';
    if(el('roi-bar'))             el('roi-bar').style.width             = Math.min(roi/10, 100)+'%';
  }
};

// ── COUNTDOWN ────────────────────────────────────────────────────
(function() {
  function updateCountdown() {
    const target = new Date('2025-12-31T23:59:59');
    const now    = new Date();
    const diff   = target - now;
    if (diff <= 0) return;
    const d = Math.floor(diff/86400000);
    const h = Math.floor((diff%86400000)/3600000);
    const m = Math.floor((diff%3600000)/60000);
    const s = Math.floor((diff%60000)/1000);
    const el = id => document.getElementById(id);
    if(el('cd-days'))  el('cd-days').textContent  = String(d).padStart(2,'0');
    if(el('cd-hours')) el('cd-hours').textContent = String(h).padStart(2,'0');
    if(el('cd-mins'))  el('cd-mins').textContent  = String(m).padStart(2,'0');
    if(el('cd-secs'))  el('cd-secs').textContent  = String(s).padStart(2,'0');
  }
  updateCountdown();
  setInterval(updateCountdown, 1000);
})();

