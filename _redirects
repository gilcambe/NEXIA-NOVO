<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Viajante Pro — Experiências de Viagem Premium</title>
  <link rel="manifest" href="manifest.json">
  <meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="theme-color" content="#FAF8F5">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800;900&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --cream:  #FAF8F5;
      --ivory:  #F5F2EC;
      --parchm: #EDE9DF;
      --bone:   #E4DFD4;
      --gold:   #B8975A;
      --gold2:  #D4AF72;
      --gold3:  #9A7D46;
      --gold-lt:rgba(184,151,90,.10);
      --ink:    #1C1A17;
      --ink2:   #3A3630;
      --ink3:   #6B6459;
      --ink4:   #A09A91;
      --ink5:   #C8C2B8;
      --white:  #FFFFFF;
      --ff: 'Inter', sans-serif;
      --ffd: 'Sora', sans-serif;
      --ffc: 'Sora', sans-serif;
      --ease: cubic-bezier(.25,.46,.45,.94);
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: var(--ff); background: var(--cream); color: var(--ink2); -webkit-font-smoothing: antialiased; overflow-x: hidden; }
    ::selection { background: var(--gold-lt); }

    /* ── NAV ─────────────────────────────────── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 200;
      height: 80px; padding: 0 64px;
      display: flex; align-items: center; justify-content: space-between;
      transition: all .4s var(--ease);
    }
    nav.solid { background: rgba(250,248,245,.95); backdrop-filter: blur(20px); border-bottom: 1px solid var(--parchm); }
    .nav-logo { font-family: var(--ffd); font-style: italic; font-size: 22px; color: var(--white); text-decoration: none; transition: color .3s; }
    nav.solid .nav-logo { color: var(--ink); }
    .nav-links { display: flex; gap: 40px; }
    .nav-links a { font-size: 10px; font-weight: 500; letter-spacing: .22em; text-transform: uppercase; color: rgba(255,255,255,.65); text-decoration: none; transition: color .2s; }
    nav.solid .nav-links a { color: var(--ink3); }
    .nav-links a:hover { color: var(--gold2) !important; }
    .btn-nav {
      font-size: 10px; font-weight: 600; letter-spacing: .2em; text-transform: uppercase;
      padding: 12px 30px; border: 1px solid rgba(255,255,255,.45); color: var(--white);
      background: transparent; text-decoration: none; transition: all .25s;
    }
    nav.solid .btn-nav { border-color: var(--gold); color: var(--gold); }
    .btn-nav:hover { background: var(--gold) !important; border-color: var(--gold) !important; color: var(--white) !important; }

    /* ── HERO ─────────────────────────────────── */
    .hero { position: relative; height: 100vh; min-height: 680px; display: flex; align-items: flex-end; overflow: hidden; }
    .hero-img {
      position: absolute; inset: 0; z-index: 0;
      background-size: cover; background-position: center;
      animation: slow-pan 24s ease infinite alternate;
    }
    @keyframes slow-pan { from { transform: scale(1) translate(0,0); } to { transform: scale(1.07) translate(-2%,1%); } }
    .hero-flash { position: absolute; inset: 0; z-index: 1; background-size: cover; background-position: center; opacity: 0; transition: opacity 2.5s ease; }
    .hero-flash.on { opacity: 1; }
    .hero-grad { position: absolute; inset: 0; z-index: 2; background: linear-gradient(180deg, rgba(28,26,23,.08) 0%, rgba(28,26,23,.15) 40%, rgba(28,26,23,.82) 100%); }
    .hero-content { position: relative; z-index: 3; padding: 0 64px 100px; max-width: 820px; }
    .hero-label { font-size: 10px; font-weight: 500; letter-spacing: .38em; text-transform: uppercase; color: var(--gold2); margin-bottom: 28px; display: flex; align-items: center; gap: 18px; }
    .hero-label::before { content: ''; width: 48px; height: 1px; background: var(--gold2); }
    .hero-h1 { font-family: var(--ffd); font-weight: 400; font-style: italic; font-size: clamp(4rem,9vw,7.5rem); color: var(--white); line-height: .9; letter-spacing: -.02em; margin-bottom: 40px; }
    .hero-row { display: flex; align-items: flex-end; gap: 56px; flex-wrap: wrap; }
    .hero-sub { font-size: 14px; font-weight: 300; color: rgba(255,255,255,.55); line-height: 1.85; max-width: 340px; }
    .btn-hero { display: inline-flex; align-items: center; gap: 12px; font-size: 10.5px; font-weight: 500; letter-spacing: .24em; text-transform: uppercase; color: var(--white); text-decoration: none; border-bottom: 1px solid rgba(255,255,255,.3); padding-bottom: 7px; transition: all .3s; white-space: nowrap; }
    .btn-hero .arr { display: inline-block; transition: transform .3s; }
    .btn-hero:hover { color: var(--gold2); border-color: var(--gold2); }
    .btn-hero:hover .arr { transform: translateX(8px); }
    .hero-scroll-hint { position: absolute; bottom: 36px; right: 64px; z-index: 3; display: flex; flex-direction: column; align-items: center; gap: 10px; }
    .hero-scroll-hint span { font-size: 8.5px; font-weight: 600; letter-spacing: .3em; text-transform: uppercase; color: rgba(255,255,255,.35); writing-mode: vertical-rl; }
    .hero-scroll-line { width: 1px; height: 56px; background: linear-gradient(to bottom, transparent, rgba(255,255,255,.4)); animation: scroll-anim 2.5s ease infinite; }
    @keyframes scroll-anim { 0%,100%{opacity:.3;transform:scaleY(1)} 50%{opacity:.9;transform:scaleY(.7);transform-origin:bottom} }

    /* ── STATS STRIP ──────────────────────────── */
    .stats-strip { background: var(--white); display: grid; grid-template-columns: repeat(4,1fr); border-bottom: 1px solid var(--parchm); }
    .stat-col { padding: 56px 40px; text-align: center; border-right: 1px solid var(--parchm); }
    .stat-col:last-child { border-right: none; }
    .stat-num { font-family: var(--ffd); font-style: italic; font-size: 2.6rem; font-weight: 400; color: var(--ink); line-height: 1; }
    .stat-lbl { font-size: 9.5px; font-weight: 600; letter-spacing: .24em; text-transform: uppercase; color: var(--ink4); margin-top: 8px; }

    /* ── SECTION UTILS ────────────────────────── */
    .sec-eyebrow { font-size: 10px; font-weight: 500; letter-spacing: .32em; text-transform: uppercase; color: var(--gold); margin-bottom: 14px; }
    .sec-h2 { font-family: var(--ffd); font-style: italic; font-weight: 400; font-size: clamp(2.2rem,4vw,3.2rem); color: var(--ink); line-height: 1.02; letter-spacing: -.01em; }
    .sec-body { font-size: 14px; font-weight: 300; line-height: 1.85; color: var(--ink3); }

    /* ── EDITORIAL DESTINATIONS ───────────────── */
    .editorial { padding: 120px 0 0; overflow: hidden; }
    .ed-header { padding: 0 64px; display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 60px; gap: 40px; }
    .btn-link { font-size: 10px; font-weight: 600; letter-spacing: .2em; text-transform: uppercase; color: var(--gold3); border-bottom: 1px solid var(--gold3); padding-bottom: 4px; text-decoration: none; transition: gap .2s, color .2s; white-space: nowrap; }
    .btn-link:hover { color: var(--gold); border-color: var(--gold); }
    .ed-grid { display: grid; grid-template-columns: 1.5fr 1fr 1fr; grid-template-rows: 520px 380px; gap: 3px; }
    .ed-card { position: relative; overflow: hidden; cursor: pointer; }
    .ed-card:first-child { grid-row: 1 / 3; }
    .ed-card-img { width: 100%; height: 100%; object-fit: cover; background-size: cover; background-position: center; transition: transform 1s var(--ease); display: block; }
    .ed-card:hover .ed-card-img { transform: scale(1.05); }
    .ed-card-veil { position: absolute; inset: 0; background: linear-gradient(to top, rgba(28,26,23,.75) 0%, rgba(28,26,23,.08) 45%, transparent 70%); opacity: 0; transition: opacity .4s; }
    .ed-card:hover .ed-card-veil { opacity: 1; }
    .ed-card-body { position: absolute; bottom: 0; left: 0; right: 0; padding: 28px 24px; transform: translateY(6px); opacity: 0; transition: all .4s var(--ease); }
    .ed-card:hover .ed-card-body { opacity: 1; transform: translateY(0); }
    .ed-tier { font-size: 8.5px; font-weight: 600; letter-spacing: .28em; text-transform: uppercase; color: var(--gold2); margin-bottom: 5px; }
    .ed-name { font-family: var(--ffd); font-style: italic; font-size: 1.6rem; color: var(--white); line-height: 1; }
    .ed-price { font-size: 11px; font-weight: 400; color: rgba(255,255,255,.6); margin-top: 4px; letter-spacing: .04em; }
    .ed-go { display: inline-flex; align-items: center; gap: 8px; margin-top: 14px; font-size: 9px; font-weight: 600; letter-spacing: .2em; text-transform: uppercase; color: var(--white); border-bottom: 1px solid rgba(255,255,255,.35); padding-bottom: 3px; text-decoration: none; }

    /* ── MURAL SOCIAL ─────────────────────────── */
    .mural { padding: 120px 0; background: var(--ivory); }
    .mural-header { padding: 0 64px; display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 60px; gap: 40px; }
    .live-badge { display: inline-flex; align-items: center; gap: 9px; font-size: 9.5px; font-weight: 600; letter-spacing: .2em; text-transform: uppercase; color: var(--gold3); border: 1px solid var(--gold3); padding: 8px 18px; }
    .live-pulse { width: 6px; height: 6px; border-radius: 50%; background: var(--gold); animation: pulse 2s infinite; }
    @keyframes pulse { 0%,100%{opacity:1}50%{opacity:.25} }
    .mural-track { display: flex; gap: 4px; overflow-x: auto; padding: 0 64px 4px; scrollbar-width: none; }
    .mural-track::-webkit-scrollbar { display: none; }
    .mural-tile { flex-shrink: 0; position: relative; overflow: hidden; cursor: pointer; }
    .mural-tile:nth-child(odd)  { width: 300px; height: 400px; align-self: flex-start; }
    .mural-tile:nth-child(even) { width: 220px; height: 340px; align-self: flex-end; }
    .mural-tile-img { width: 100%; height: 100%; object-fit: cover; background-size: cover; background-position: center; transition: transform .8s var(--ease); display: block; }
    .mural-tile:hover .mural-tile-img { transform: scale(1.06); }
    .mural-tile-info { position: absolute; bottom: 0; left: 0; right: 0; padding: 18px 16px; background: linear-gradient(to top, rgba(28,26,23,.68), transparent); opacity: 0; transition: opacity .35s; }
    .mural-tile:hover .mural-tile-info { opacity: 1; }
    .mural-tile-author { font-size: 11px; font-weight: 600; color: var(--white); }
    .mural-tile-caption { font-size: 10px; font-weight: 300; color: rgba(255,255,255,.65); margin-top: 2px; }
    .mural-add-tile { flex-shrink: 0; width: 220px; height: 340px; align-self: flex-end; border: 1px solid var(--bone); background: var(--white); display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 14px; cursor: pointer; transition: all .3s; }
    .mural-add-tile:hover { border-color: var(--gold2); background: var(--cream); }
    .add-icon { font-size: 24px; color: var(--ink5); transition: color .3s; }
    .mural-add-tile:hover .add-icon { color: var(--gold); }
    .add-lbl { font-size: 9px; font-weight: 600; letter-spacing: .26em; text-transform: uppercase; color: var(--ink5); text-align: center; transition: color .3s; }
    .mural-add-tile:hover .add-lbl { color: var(--gold3); }
    .mural-cta-row { padding: 44px 64px 0; }

    /* ── PARTNERS ─────────────────────────────── */
    .partners { background: var(--white); border-top: 1px solid var(--parchm); padding: 72px 64px; }
    .partners-lbl { font-size: 9.5px; font-weight: 600; letter-spacing: .32em; text-transform: uppercase; color: var(--ink5); text-align: center; margin-bottom: 44px; }
    .partners-row { display: flex; align-items: center; justify-content: center; max-width: 1200px; margin: 0 auto; }
    .partner { flex: 1; text-align: center; padding: 18px 28px; border-right: 1px solid var(--parchm); transition: background .2s; }
    .partner:last-child { border-right: none; }
    .partner:hover { background: var(--cream); }
    .partner-name { font-family: var(--ffc); font-size: 1.15rem; color: var(--ink4); transition: color .2s; }
    .partner:hover .partner-name { color: var(--gold); }
    .partner-role { font-size: 9px; font-weight: 600; letter-spacing: .18em; text-transform: uppercase; color: var(--ink5); margin-top: 4px; }

    /* ── ABOUT ────────────────────────────────── */
    .about { padding: 140px 64px; background: var(--cream); }
    .about-grid { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 100px; align-items: center; }
    .about-photo { position: relative; }
    .about-photo img { width: 100%; aspect-ratio: 3/4; object-fit: cover; display: block; }
    .about-badge { position: absolute; bottom: -28px; right: -28px; background: var(--white); padding: 28px 32px; box-shadow: 0 8px 40px rgba(28,26,23,.1); }
    .badge-val { font-family: var(--ffd); font-style: italic; font-size: 3rem; color: var(--gold); line-height: 1; }
    .badge-lbl { font-size: 9px; font-weight: 600; letter-spacing: .22em; text-transform: uppercase; color: var(--ink4); margin-top: 6px; }
    .about-features { margin-top: 48px; }
    .feat { display: flex; gap: 22px; padding: 22px 0; border-bottom: 1px solid var(--parchm); }
    .feat:first-child { border-top: 1px solid var(--parchm); }
    .feat-n { font-family: var(--ffc); font-style: italic; font-size: .9rem; color: var(--gold3); width: 22px; flex-shrink: 0; padding-top: 2px; }
    .feat-t { font-size: 10.5px; font-weight: 600; letter-spacing: .12em; text-transform: uppercase; color: var(--ink); margin-bottom: 5px; }
    .feat-d { font-size: 13.5px; font-weight: 300; color: var(--ink3); line-height: 1.72; }

    /* ── TESTIMONIALS ─────────────────────────── */
    .testimonials { background: var(--white); padding: 120px 64px; }
    .test-inner { max-width: 1200px; margin: 0 auto; }
    .test-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1px; margin-top: 64px; background: var(--parchm); border: 1px solid var(--parchm); }
    .test-card { background: var(--white); padding: 48px 38px; display: flex; flex-direction: column; gap: 22px; transition: background .3s; }
    .test-card:hover { background: var(--cream); }
    .test-stars { color: var(--gold); font-size: 11px; letter-spacing: 3px; }
    .test-quote { font-family: var(--ffd); font-style: italic; font-size: 1rem; color: var(--ink2); line-height: 1.75; flex: 1; }
    .test-hr { height: 1px; background: var(--parchm); }
    .test-author { display: flex; gap: 13px; align-items: center; }
    .test-av { width: 42px; height: 42px; border-radius: 50%; overflow: hidden; border: 1px solid var(--parchm); flex-shrink: 0; }
    .test-av img { width: 100%; height: 100%; object-fit: cover; }
    .test-name { font-size: 12px; font-weight: 600; color: var(--ink); }
    .test-role { font-size: 10.5px; font-weight: 300; color: var(--ink4); margin-top: 1px; }

    /* ── CES PANEL ────────────────────────────── */
    .ces { display: grid; grid-template-columns: 1fr 1fr; min-height: 560px; }
    .ces-visual { background: url('https://images.unsplash.com/photo-1605833556294-ea5c7a74f57d?w=1400&q=85') center/cover; position: relative; }
    .ces-visual::after { content: ''; position: absolute; inset: 0; background: linear-gradient(to right, transparent 55%, rgba(28,26,23,.85) 100%); }
    .ces-text { background: var(--ink); padding: 100px 72px; display: flex; flex-direction: column; justify-content: center; }
    .ces-eyebrow { font-size: 10px; font-weight: 500; letter-spacing: .32em; text-transform: uppercase; color: var(--gold2); margin-bottom: 16px; }
    .ces-h2 { font-family: var(--ffd); font-style: italic; font-weight: 400; font-size: clamp(2rem,4vw,3rem); color: var(--white); line-height: 1.02; margin-bottom: 24px; }
    .ces-body { font-size: 14px; font-weight: 300; color: rgba(255,255,255,.5); line-height: 1.85; margin-bottom: 48px; max-width: 360px; }
    .btn-ces { display: inline-flex; align-items: center; gap: 12px; font-size: 10.5px; font-weight: 600; letter-spacing: .22em; text-transform: uppercase; color: var(--white); border-bottom: 1px solid rgba(255,255,255,.3); padding-bottom: 6px; text-decoration: none; transition: all .25s; width: fit-content; }
    .btn-ces .arr { transition: transform .3s; }
    .btn-ces:hover { color: var(--gold2); border-color: var(--gold2); }
    .btn-ces:hover .arr { transform: translateX(8px); }

    /* ── CTA ──────────────────────────────────── */
    .cta { padding: 160px 64px; text-align: center; background: var(--cream); position: relative; overflow: hidden; }
    .cta::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse 70% 50% at 50% 110%, rgba(184,151,90,.06), transparent 60%); pointer-events: none; }
    .cta-inner { max-width: 600px; margin: 0 auto; position: relative; }
    .cta-h2 { font-family: var(--ffd); font-style: italic; font-weight: 400; font-size: clamp(2.6rem,5vw,4.2rem); color: var(--ink); line-height: .95; letter-spacing: -.015em; margin: 14px 0 22px; }
    .cta-sub { font-size: 14px; font-weight: 300; color: var(--ink3); line-height: 1.85; margin-bottom: 52px; }
    .btn-cta { display: inline-block; padding: 18px 60px; font-size: 10.5px; font-weight: 600; letter-spacing: .26em; text-transform: uppercase; background: var(--ink); color: var(--white); text-decoration: none; transition: all .3s; box-shadow: 0 4px 32px rgba(28,26,23,.12); }
    .btn-cta:hover { background: var(--gold); box-shadow: 0 8px 40px rgba(184,151,90,.28); }
    .btn-cta-ghost { display: inline-block; margin-left: 16px; padding: 17px 40px; font-size: 10.5px; font-weight: 600; letter-spacing: .22em; text-transform: uppercase; border: 1px solid var(--gold); color: var(--gold); text-decoration: none; transition: all .3s; }
    .btn-cta-ghost:hover { background: var(--gold); color: var(--white); }

    /* ── FOOTER ───────────────────────────────── */
    footer { background: var(--ink); padding: 60px 64px; display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 40px; }
    .f-logo { font-family: var(--ffd); font-style: italic; font-size: 20px; color: rgba(255,255,255,.38); }
    .f-links { display: flex; gap: 32px; justify-content: center; flex-wrap: wrap; }
    .f-links a { font-size: 9px; font-weight: 500; letter-spacing: .22em; text-transform: uppercase; color: rgba(255,255,255,.28); text-decoration: none; transition: color .2s; }
    .f-links a:hover { color: var(--gold2); }
    .f-copy { font-size: 9.5px; letter-spacing: .1em; color: rgba(255,255,255,.18); text-align: right; line-height: 1.6; }

    /* ── REVEAL ───────────────────────────────── */
    .reveal { opacity: 0; transform: translateY(24px); transition: opacity .8s var(--ease), transform .8s var(--ease); }
    .reveal.vis { opacity: 1; transform: none; }
    .d1 { transition-delay: .1s; } .d2 { transition-delay: .2s; } .d3 { transition-delay: .3s; } .d4 { transition-delay: .45s; }

    /* ── RESPONSIVE ───────────────────────────── */
    @media(max-width:1024px) {
      nav, .about, .testimonials, .cta, .partners { padding-left: 40px; padding-right: 40px; }
      .ed-header, .mural-header, .mural-track, .mural-cta-row { padding-left: 40px; }
      .hero-content { padding-left: 40px; padding-right: 40px; }
      .hero-scroll-hint { right: 40px; }
      .about-grid { gap: 60px; }
    }
    @media(max-width:768px) {
      nav { padding: 0 24px; }
      .nav-links { display: none; }
      .hero-content { padding: 0 24px 80px; }
      .hero-scroll-hint { display: none; }
      .stats-strip { grid-template-columns: 1fr 1fr; }
      .stat-col:nth-child(2) { border-right: none; }
      .stat-col:nth-child(3) { border-right: 1px solid var(--parchm); border-top: 1px solid var(--parchm); }
      .stat-col:nth-child(4) { border-top: 1px solid var(--parchm); border-right: none; }
      .editorial { padding: 80px 0 0; }
      .ed-header { flex-direction: column; align-items: flex-start; padding: 0 24px; }
      .ed-grid { grid-template-columns: 1fr 1fr; grid-template-rows: auto; }
      .ed-grid .ed-card:first-child { grid-column: 1/-1; height: 320px; grid-row: auto; }
      .ed-grid .ed-card { height: 220px; }
      .mural { padding: 80px 0; }
      .mural-header { padding: 0 24px; flex-direction: column; align-items: flex-start; }
      .mural-track, .mural-cta-row { padding-left: 24px; }
      .partners { padding: 60px 24px; }
      .partners-row { flex-wrap: wrap; }
      .partner { min-width: 50%; border-right: none !important; border-bottom: 1px solid var(--parchm); }
      .about { padding: 80px 24px; }
      .about-grid { grid-template-columns: 1fr; gap: 48px; }
      .about-badge { right: 0; }
      .testimonials { padding: 80px 24px; }
      .test-grid { grid-template-columns: 1fr; }
      .ces { grid-template-columns: 1fr; }
      .ces-visual { height: 280px; }
      .ces-text { padding: 56px 32px; }
      .cta { padding: 100px 24px; }
      footer { grid-template-columns: 1fr; text-align: center; padding: 48px 24px; gap: 28px; }
      .f-copy { text-align: center; }
      .f-links { justify-content: center; }
    }
  </style>
  <!-- ✅ Firebase SDKs — necessários para checkout e tema dinâmico -->
  <script src="https://www.gstatic.com/firebasejs/9.22.2/firebase-app-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/9.22.2/firebase-firestore-compat.js"></script>
