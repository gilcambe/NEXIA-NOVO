// Hero image cycle
const flashes = [document.getElementById('f0'),document.getElementById('f1'),document.getElementById('f2'),document.getElementById('f3')];
let fi = 0;
(function cycle(){
  flashes.forEach(f=>f.classList.remove('on'));
