// ── ✅ FUNÇÃO CHECKOUT — dispara pagamento via Netlify Functions
async function checkout(packageName, price) {
  try {
    const btn = event?.target;
    if (btn) { btn.textContent = 'Aguarde…'; btn.style.opacity = '0.6'; btn.style.pointerEvents = 'none'; }
    const res = await fetch('/.netlify/functions/checkout', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ moduleName: packageName, price, tenantId: 'VP_AGENCIA_01', moduleId: 'PACK' })
    });
    if (!res.ok) throw new Error('Resposta HTTP ' + res.status);
    const data = await res.json();
    if (data?.init_point) { window.location.href = data.init_point; }
    else { throw new Error('init_point não retornado pelo servidor'); }
  } catch (err) {
    console.error('[VP Checkout]', err);
    const btn = event?.target;
    if (btn) { btn.textContent = 'Reservar →'; btn.style.opacity = ''; btn.style.pointerEvents = ''; }
    alert('Não foi possível iniciar o pagamento. Por favor, tente novamente ou entre em contato.');
  }
}

