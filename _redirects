// ── ✅ TEMA DINÂMICO — aguarda NEXIA.db do config.js e faz onSnapshot
(function watchSiteConfig() {
  var _started = false;
  var _iv = setInterval(function() {
    if (typeof NEXIA === 'undefined' || !NEXIA.db) return;
    clearInterval(_iv);
    if (_started) return;
    _started = true;
    NEXIA.db
      .collection('tenants')
      .doc('VP_AGENCIA_01')
      .collection('public_site')
      .doc('config')
      .onSnapshot(function(doc) {
